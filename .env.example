# Public Gemini API key used by the browser app for live client-side features.
# Use a restricted key and never reuse a privileged server secret here.
VITE_API_KEY=your_public_gemini_api_key

# WebSocket server URL for the realtime voice pipeline.
VITE_WS_URL=ws://localhost:3001/ws

# Server-side AI + speech credentials
DEEPGRAM_API_KEY=af2a111b30319191c42086846041df2fe412544e
GEMINI_API_KEY=your_server_side_gemini_api_key
PORT=3001

# Optional aliases for local tooling only.
REACT_APP_API_KEY=your_public_gemini_api_key

# Firebase configuration (used by email sign-up/sign-in)
VITE_FIREBASE_API_KEY=your_firebase_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com

# Razorpay public key for checkout
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id

# Optional backend URL used for STT transcript -> backend -> Gemini REST pipeline
VITE_BACKEND_API_URL=http://localhost:3000/api

# Recommended server-side hardening configuration
ALLOWED_APP_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-production-domain.example
SUBSCRIPTION_ADMIN_SECRET=replace_with_a_long_random_secret
RAZORPAY_WEBHOOK_SECRET=replace_with_your_razorpay_webhook_secret
